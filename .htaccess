RewriteEngine On

RewriteRule ^media\.php$ - [L]

RewriteRule ^player\.html$ - [L,NC]

<FilesMatch "^(index|media)\.php$|^player\.html$">
    Require all granted
</FilesMatch>

<FilesMatch "^player\.html$">
    Header always set Content-Security-Policy "frame-ancestors 'self' https://dcote.net https://dcote.online"
    Allow-Origin "*"
    Header always set Access-Control-
    Header always set Access-Control-Allow-Methods "GET, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, Range"
    Header always set Access-Control-Expose-Headers "Content-Range, Content-Length"
</FilesMatch>

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/media\.php
RewriteCond %{REQUEST_URI} !^/player\.html
RewriteRule ^(.*)$ index.php [QSA,L]